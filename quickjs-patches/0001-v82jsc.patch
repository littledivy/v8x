+/* v82jsc patch: return the JSVarRef backing a FOUND *local* export.
+   `import X from "m"; export { X }` makes X a LOCAL export whose var_ref lives in
+   this module's own import slot. While a peer in an import cycle is still
+   unlinked that slot is NULL, and upstream QuickJS-ng then either dereferences
+   the NULL (crash, in js_inner_module_linking) or treats it as a spurious
+   circular reference (in js_build_module_ns). Per spec the indirect binding
+   exists for the whole SCC's instantiation, so when the slot is NULL we follow
+   the import alias to its source module and resolve the binding there (the
+   source's local var_ref is already allocated by js_create_module_function).
+   Returns NULL only if genuinely unresolvable. */
+static JSVarRef *js_get_local_export_var_ref(JSContext *ctx, JSModuleDef *res_m,
+                                             JSExportEntry *res_me)
+{
+    JSVarRef *var_ref = res_me->u.local.var_ref;
+    if (!var_ref) {
+        JSObject *p1 = JS_VALUE_GET_OBJ(res_m->func_obj);
+        var_ref = p1->u.func.var_refs[res_me->u.local.var_idx];
+    }
+    if (!var_ref) {
+        int k;
+        for (k = 0; k < res_m->import_entries_count; k++) {
+            JSImportEntry *imp = &res_m->import_entries[k];
+            if (imp->var_idx == res_me->u.local.var_idx) {
+                JSModuleDef *src_m =
+                    res_m->req_module_entries[imp->req_module_idx].module;
+                JSModuleDef *r2_m;
+                JSExportEntry *r2_me;
+                JSResolveResultEnum r2 =
+                    js_resolve_export(ctx, &r2_m, &r2_me, src_m, imp->import_name);
+                if (r2 == JS_RESOLVE_RES_FOUND &&
+                    r2_me->local_name != JS_ATOM__star_)
+                    var_ref = js_get_local_export_var_ref(ctx, r2_m, r2_me);
+                break;
+            }
+        }
+    }
+    return var_ref;
+}
