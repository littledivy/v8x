[submodule "vendor/webkit"]
	path = vendor/webkit
	url = https://github.com/WebKit/WebKit.git
	shallow = true
	ignore = dirty
[submodule "vendor/quickjs-ng"]
	path = vendor/quickjs-ng
	url = https://github.com/quickjs-ng/quickjs.git
	ignore = dirty
[submodule "vendor/wamr"]
	path = vendor/wamr
	url = https://github.com/bytecodealliance/wasm-micro-runtime.git
	ignore = dirty
