{
  "$schema": "./config.schema.json",
  "comment": "Single source of truth for the test matrix. Backends x suites. The runner (run.mjs), the aggregator (aggregate.mjs) and CI all read this.",
  "backends": [
    {
      "id": "jsc",
      "label": "JavaScriptCore",
      "features": "engine_jsc,vendor_jsc",
      "os": "macos",
      "comment": "WebKit JSCOnly built from source. The shippable engine."
    },
    {
      "id": "sys-jsc",
      "label": "JavaScriptCore System",
      "features": "system_jsc",
      "os": "macos",
      "comment": "Apple's JavaScriptCore.framework. String-rewriter module shim."
    },
    {
      "id": "quickjs",
      "label": "QuickJS-ng",
      "features": "quickjs",
      "os": "any",
      "comment": "Vendored quickjs-ng, statically linked. Cross-platform."
    }
  ],
  "suites": [
    {
      "id": "rusty_v8",
      "label": "rusty_v8 API",
      "tier": "build",
      "kind": "cargo-self",
      "comment": "Vendored rusty_v8 integration tests run unmodified against our v8 shim (see [[test]] entries in Cargo.toml). Cheapest: no deno.",
      "cargo_tests": [
        "rv8_test_api",
        "rv8_test_api_flags",
        "rv8_test_api_entropy_source",
        "rv8_slots",
        "rv8_test_simple_external",
        "rv8_test_external_deserialize",
        "rv8_test_custom_platform",
        "rv8_test_single_threaded_default_platform",
        "rv8_test_platform_atomics_pump_message_loop",
        "rv8_test_concurrent_isolate_creation_and_disposal",
        "rv8_test_cppgc"
      ],
      "ignore_comment": "concurrent_isolate_creation_and_disposal races and SIGABRTs ~75% of CI runs on quickjs (Linux) — a genuine concurrency flake that was blocking every PR. Quarantined on quickjs until the underlying isolate create/dispose race is fixed.",
      "ignore": [],
      "ignore_by_backend": {
        "quickjs": [
          "concurrent_isolate_creation_and_disposal"
        ]
      }
    },
    {
      "id": "deno_core",
      "label": "deno_core",
      "tier": "build",
      "kind": "cargo-deno",
      "comment": "cargo test -p deno_core in the patched deno checkout. Links our v8 shim but does NOT build the full deno binary.",
      "package": "deno_core",
      "ignore_comment": "Known-flaky / platform-broken tests, quarantined from the ratchet (NEVER run; excluded from pass/fail/baseline) so the cell is deterministic. `ignore`=all backends, `ignore_by_backend`=per-backend; bare libtest paths (no `deno_core::` prefix). On quickjs (Linux CI) the entire `runtime::ops::tests::*` family is unreliable — a broken op-call ABI makes them crash (SIGSEGV/SIGBUS) non-deterministically (18/43 stable, 5 flaky, 20 always-crash across observed runs) — so the whole family is quarantined wholesale pending a quickjs op-ABI fix; plus the no-op-TerminateExecution hangs (terminate*/heap), dyn_import_recurse_err (ASLR stack-overflow) and a few code-cache/lazy-esm module tests. The JSC backends do not need any of these.",
      "ignore": [],
      "ignore_by_backend": {
        "quickjs": [
          "modules::tests::dyn_import_recurse_err",
          "modules::tests::test_dyn_import_async_graph_with_lazy_esm_no_stall",
          "modules::tests::test_lazy_loaded_esm_with_tla_no_panic",
          "modules::tests::test_load_with_code_cache",
          "runtime::ops::tests::return_buffers",
          "runtime::ops::tests::test_external",
          "runtime::ops::tests::test_external_null",
          "runtime::ops::tests::test_isolate",
          "runtime::ops::tests::test_jsruntimestate",
          "runtime::ops::tests::test_op_64",
          "runtime::ops::tests::test_op_add",
          "runtime::ops::tests::test_op_add_option",
          "runtime::ops::tests::test_op_add_smi",
          "runtime::ops::tests::test_op_arraybuffer_slice",
          "runtime::ops::tests::test_op_async_buffer",
          "runtime::ops::tests::test_op_async_deferred",
          "runtime::ops::tests::test_op_async_external",
          "runtime::ops::tests::test_op_async_lazy",
          "runtime::ops::tests::test_op_async_number",
          "runtime::ops::tests::test_op_async_result_impl",
          "runtime::ops::tests::test_op_async_serde_option_v8",
          "runtime::ops::tests::test_op_async_sleep",
          "runtime::ops::tests::test_op_async_sleep_error",
          "runtime::ops::tests::test_op_async_state",
          "runtime::ops::tests::test_op_async_void",
          "runtime::ops::tests::test_op_bool",
          "runtime::ops::tests::test_op_bool_to_from_v8",
          "runtime::ops::tests::test_op_buffer_any",
          "runtime::ops::tests::test_op_buffer_any_length",
          "runtime::ops::tests::test_op_buffer_bytesmut",
          "runtime::ops::tests::test_op_buffer_copy",
          "runtime::ops::tests::test_op_buffer_jsbuffer",
          "runtime::ops::tests::test_op_buffer_slice",
          "runtime::ops::tests::test_op_cppgc_object",
          "runtime::ops::tests::test_op_fail",
          "runtime::ops::tests::test_op_float",
          "runtime::ops::tests::test_op_number_to_from_v8",
          "runtime::ops::tests::test_op_result_primitive",
          "runtime::ops::tests::test_op_result_void",
          "runtime::ops::tests::test_op_result_void_switch",
          "runtime::ops::tests::test_op_serde_v8",
          "runtime::ops::tests::test_op_smi_to_from_v8",
          "runtime::ops::tests::test_op_state",
          "runtime::ops::tests::test_op_string_returns",
          "runtime::ops::tests::test_op_strings",
          "runtime::ops::tests::test_op_v8_types",
          "runtime::ops::tests::test_typed_external",
          "runtime::tests::misc::eval_context_with_code_cache",
          "runtime::tests::misc::terminate_execution",
          "runtime::tests::misc::terminate_execution_run_event_loop_js",
          "runtime::tests::misc::terminate_execution_webassembly",
          "runtime::tests::misc::test_heap_limit_cb_multiple",
          "runtime::tests::misc::test_heap_limits"
        ]
      }
    }
  ]
}
