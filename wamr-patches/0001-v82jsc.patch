@@ -4494,10 +4505,41 @@ wasm_memory_size(const wasm_memory_t *memory)
 bool
 wasm_memory_grow(wasm_memory_t *memory, wasm_memory_pages_t delta)
 {
-    (void)memory;
-    (void)delta;
-    LOG_WARNING("Calling wasm_memory_grow() by host is not supported."
-                "Only allow growing a memory via the opcode memory.grow");
+    /* v82jsc: host-side memory grow IS needed — `WebAssembly.Memory.prototype.grow`
+     * is called from JS (e.g. es-module-lexer grows its heap before writing the
+     * source to parse). Delegate to the same runtime routine the memory.grow
+     * opcode uses. */
+    if (!memory || !memory->inst_comm_rt) {
+        return false;
+    }
+#if WASM_ENABLE_INTERP != 0
+    if (memory->inst_comm_rt->module_type == Wasm_Module_Bytecode) {
+        WASMModuleInstance *mi = (WASMModuleInstance *)memory->inst_comm_rt;
+        /* A memory declared without an explicit maximum gets max_page_count
+         * pinned to its initial size by our load path, which blocks host-driven
+         * `WebAssembly.Memory.grow` (es-module-lexer grows its 1-page heap to hold
+         * the source). V8 lets such memories grow to the engine limit, so raise
+         * the cap to accommodate this grow (bounded by the 4GiB page limit). */
+        WASMMemoryInstance *m = (mi->memories && memory->memory_idx_rt < mi->memory_count)
+                                    ? mi->memories[memory->memory_idx_rt]
+                                    : NULL;
+        if (m) {
+            uint64 want = (uint64)m->cur_page_count + (uint64)delta;
+            if (want > (uint64)m->max_page_count && want <= DEFAULT_MAX_PAGES) {
+                m->max_page_count = (uint32)want;
+            }
+        }
+        return wasm_enlarge_memory_with_idx(mi, delta, memory->memory_idx_rt);
+    }
+#endif
+#if WASM_ENABLE_AOT != 0
+    if (memory->inst_comm_rt->module_type == Wasm_Module_AoT) {
+        return aot_enlarge_memory_with_idx(
+            (AOTModuleInstance *)memory->inst_comm_rt, delta,
+            memory->memory_idx_rt);
+    }
+#endif
+    LOG_WARNING("wasm_memory_grow() unsupported for this module type");
     return false;
 }
 
