+
+int v82jsc_module_stalled_location(JSModuleDef *m, int *line, int *column)
+{
+    JSAsyncFunctionData *s;
+    JSStackFrame *sf;
+    JSObject *p;
+    JSFunctionBytecode *b;
+    uint32_t pc;
+
+    if (!m || !line || !column)
+        return 0;
+    s = m->async_func_state;
+    if (!s || !s->is_active)
+        return 0;
+    sf = &s->func_state.frame;
+    if (!sf->cur_pc || JS_VALUE_GET_TAG(sf->cur_func) != JS_TAG_OBJECT)
+        return 0;
+    p = JS_VALUE_GET_OBJ(sf->cur_func);
+    if (!js_class_has_bytecode(p->class_id))
+        return 0;
+    b = p->u.func.function_bytecode;
+    if (!b || sf->cur_pc <= b->byte_code_buf ||
+        sf->cur_pc > b->byte_code_buf + b->byte_code_len)
+        return 0;
+    pc = sf->cur_pc - b->byte_code_buf - 1;
+    *line = find_line_num(b->realm, b, pc, column);
+    return *line > 0;
+}
