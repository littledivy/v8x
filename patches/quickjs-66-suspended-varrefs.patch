+static void set_stack_frame_gc_owner(JSRuntime *rt, JSStackFrame *sf,
+                                     JSValueConst gc_owner)
+{
+    int i;
+
+    assert(!JS_IsUndefined(gc_owner));
+    sf->gc_owner = unsafe_unconst(gc_owner);
+    for (i = 0; i < sf->var_ref_count; i++) {
+        JSVarRef *var_ref = sf->var_refs[i];
+        if (var_ref && JS_IsUndefined(var_ref->gc_owner)) {
+            assert(!var_ref->is_detached);
+            var_ref->gc_owner = js_dup(gc_owner);
+            add_gc_object(rt, &var_ref->header, JS_GC_OBJ_TYPE_VAR_REF);
+        }
+    }
