+static bool js_error_has_native_stack_accessor(JSContext *ctx, JSObject *p)
+{
+    JSObject *proto;
+    JSProperty *prop, *proto_prop;
+    JSShapeProperty *shape_prop, *proto_shape_prop;
+
+    if (p->class_id != JS_CLASS_ERROR ||
+        JS_VALUE_GET_TAG(ctx->class_proto[JS_CLASS_ERROR]) != JS_TAG_OBJECT)
+        return false;
+    shape_prop = find_own_property(&prop, p, JS_ATOM_stack);
+    if (!shape_prop ||
+        (shape_prop->flags & JS_PROP_TMASK) != JS_PROP_GETSET)
+        return false;
+    proto = JS_VALUE_GET_OBJ(ctx->class_proto[JS_CLASS_ERROR]);
+    proto_shape_prop = find_own_property(&proto_prop, proto, JS_ATOM_stack);
+    return proto_shape_prop &&
+           (proto_shape_prop->flags & JS_PROP_TMASK) == JS_PROP_GETSET &&
+           prop->u.getset.getter == proto_prop->u.getset.getter &&
+           prop->u.getset.setter == proto_prop->u.getset.setter;
+}
+
+static int js_error_define_stack_accessor(JSContext *ctx, JSValueConst obj)
+{
+    JSObject *p, *proto;
+    JSProperty *proto_prop;
+    JSShapeProperty *proto_shape_prop;
+    JSValue getter, setter;
+
+    if (JS_VALUE_GET_TAG(obj) != JS_TAG_OBJECT)
+        return 0;
+    p = JS_VALUE_GET_OBJ(obj);
+    if (p->class_id != JS_CLASS_ERROR ||
+        find_own_property1(p, JS_ATOM_stack) ||
+        JS_VALUE_GET_TAG(ctx->class_proto[JS_CLASS_ERROR]) != JS_TAG_OBJECT)
+        return 0;
+    proto = JS_VALUE_GET_OBJ(ctx->class_proto[JS_CLASS_ERROR]);
+    proto_shape_prop = find_own_property(&proto_prop, proto, JS_ATOM_stack);
+    if (!proto_shape_prop ||
+        (proto_shape_prop->flags & JS_PROP_TMASK) != JS_PROP_GETSET)
+        return 0;
+    getter = proto_prop->u.getset.getter
+                 ? js_dup(JS_MKPTR(JS_TAG_OBJECT,
+                                   proto_prop->u.getset.getter))
+                 : JS_UNDEFINED;
+    setter = proto_prop->u.getset.setter
+                 ? js_dup(JS_MKPTR(JS_TAG_OBJECT,
+                                   proto_prop->u.getset.setter))
+                 : JS_UNDEFINED;
+    return JS_DefinePropertyGetSet(ctx, obj, JS_ATOM_stack, getter, setter,
+                                   JS_PROP_CONFIGURABLE);
+}
