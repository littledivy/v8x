+static bool js_v82jsc_text_stack_has_same_async_site(JSContext *ctx,
+                                                      JSValueConst stack,
+                                                      const char *file,
+                                                      int line,
+                                                      const char *func)
+{
+    const char *text, *frame, *frame_end, *match, *p;
+    const char *func_start, *func_end;
+    size_t len, file_len, func_len;
+    int site_line;
+    bool same = false;
+
+    if (!JS_IsString(stack) || line < 0)
+        return false;
+    text = JS_ToCStringLen(ctx, &len, stack);
+    if (!text) {
+        if (JS_HasException(ctx))
+            JS_FreeValue(ctx, JS_GetException(ctx));
+        return false;
+    }
+    frame = text;
+    while (frame < text + len && strncmp(frame, "    at ", 7)) {
+        frame = memchr(frame, '\n', text + len - frame);
+        if (!frame)
+            goto done;
+        frame++;
+    }
+    frame_end = memchr(frame, '\n', text + len - frame);
+    if (!frame_end)
+        frame_end = text + len;
+    file_len = strlen(file);
+    for (match = frame;
+         (size_t)(frame_end - match) > file_len;
+         match++) {
+        if (memcmp(match, file, file_len) || match[file_len] != ':')
+            continue;
+        p = match + file_len + 1;
+        if (p >= frame_end || *p < '0' || *p > '9')
+            continue;
+        site_line = 0;
+        do {
+            site_line = site_line * 10 + (*p++ - '0');
+        } while (p < frame_end && *p >= '0' && *p <= '9');
+        if (site_line != line)
+            continue;
+        if (func && (size_t)(match - frame) >= 9 && match[-1] == '(' &&
+            match[-2] == ' ') {
+            func_start = frame + 7;
+            if (frame_end - func_start >= 6 &&
+                !memcmp(func_start, "async ", 6))
+                func_start += 6;
+            func_end = match - 2;
+            func_len = strlen(func);
+            if ((size_t)(func_end - func_start) != func_len ||
+                memcmp(func_start, func, func_len))
+                continue;
+        }
+        same = true;
+        break;
+    }
+ done:
+    JS_FreeCString(ctx, text);
+    return same;
+}
