+typedef JSValue JSJobContextCapture(JSContext *ctx, void *opaque);
+typedef void JSJobContextSet(JSContext *ctx, JSValueConst value, void *opaque);
+
+/* The capture hook returns an owned value that is retained with each queued
+   job. The set hook receives that value immediately before the job runs and
+   JS_UNDEFINED immediately afterward. */
+JS_EXTERN void JS_SetJobContextHooks(JSRuntime *rt,
+                                     JSJobContextCapture *capture,
+                                     JSJobContextSet *set, void *opaque);
