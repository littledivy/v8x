+JSValue v82jsc_eval_no_side_effect(JSContext *ctx,
+                                   const char *input,
+                                   size_t input_len,
+                                   const char *filename)
+{
+    JSValue bytecode, function, result;
+
+    if (unlikely(ctx->v82jsc_throw_on_side_effect))
+        return JS_ThrowEvalError(ctx,
+                                 "Possible side-effect in debug-evaluate");
+
+    bytecode = JS_Eval(ctx, input, input_len, filename,
+                       JS_EVAL_TYPE_GLOBAL | JS_EVAL_FLAG_COMPILE_ONLY);
+    if (JS_IsException(bytecode))
+        return bytecode;
+    if (JS_VALUE_GET_TAG(bytecode) != JS_TAG_FUNCTION_BYTECODE) {
+        JS_FreeValue(ctx, bytecode);
+        return JS_ThrowEvalError(ctx,
+                                 "Possible side-effect in debug-evaluate");
+    }
+
+    function = js_closure(ctx, bytecode, NULL, NULL);
+    if (JS_IsException(function))
+        return function;
+
+    ctx->v82jsc_throw_on_side_effect = true;
+    ctx->v82jsc_side_effect_root = JS_VALUE_GET_OBJ(function);
+    result = JS_CallFree(ctx, function, ctx->global_obj, 0, NULL);
+    ctx->v82jsc_side_effect_root = NULL;
+    ctx->v82jsc_throw_on_side_effect = false;
+    return result;
+}
+
 JSValue JS_Eval2(JSContext *ctx, const char *input, size_t input_len, JSEvalOptions *options)
 {
     return JS_EvalThis2(ctx, ctx->global_obj, input, input_len, options);
