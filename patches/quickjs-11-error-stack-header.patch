+/* v82jsc: v8's `Error.prototype.stack` is `<name>: <message>\n<frames>`, with
+   the header computed lazily from the error's current name/message at access
+   time. quickjs-ng stores only the (already v8-format `    at ...`) frames in
+   [[ErrorData]] and omits the header. Prepend it here so deno's console/error
+   formatting and the error_stack tests match v8 — natively, which also covers
+   engine-thrown errors (e.g. the AggregateError from Promise.any) that a JS
+   constructor wrapper cannot intercept. A prepareStackTrace result already
+   carries its own header (its first line is not a frame), so pass it through. */
+/* v82jsc: given the raw `    at ...` frame string in `frames_v` (which this
+   consumes), return `<name>: <message>\n<frames>` using `error_obj`'s current
+   name/message — v8's Error.stack header. If `frames_v` isn't a raw frame
+   string (e.g. a prepareStackTrace result that already carries its own header,
+   or a non-string), it is returned unchanged. */
+static JSValue js_error_prepend_stack_header(JSContext *ctx,
+                                             JSValueConst error_obj,
+                                             JSValue frames_v)
+{
+    JSValue name_v, msg_v, res;
+    const char *frames_s, *name_s, *msg_s, *nm, *mg, *q;
+    size_t frames_len, name_len, msg_len, nml, mgl;
+    DynBuf dbuf;
+
+    if (!JS_IsString(frames_v))
+        return frames_v;
+    frames_s = JS_ToCStringLen(ctx, &frames_len, frames_v);
+    if (!frames_s) {
+        JS_FreeValue(ctx, frames_v);
+        return JS_EXCEPTION;
+    }
+    q = frames_s;
+    while (*q == ' ' || *q == '\t')
+        q++;
+    if (!(frames_len == 0 ||
+          (q[0] == 'a' && q[1] == 't' && (q[2] == ' ' || q[2] == '\0')))) {
+        JS_FreeCString(ctx, frames_s);
+        return frames_v; /* already has a header */
+    }
+    name_v = JS_GetProperty(ctx, error_obj, JS_ATOM_name);
+    msg_v = JS_GetProperty(ctx, error_obj, JS_ATOM_message);
+    name_s = JS_IsUndefined(name_v) ? NULL
+                                    : JS_ToCStringLen(ctx, &name_len, name_v);
+    msg_s = JS_IsUndefined(msg_v) ? NULL
+                                  : JS_ToCStringLen(ctx, &msg_len, msg_v);
+    nm = name_s ? name_s : "Error";
+    nml = name_s ? name_len : 5;
+    mg = msg_s ? msg_s : "";
+    mgl = msg_s ? msg_len : 0;
+    js_dbuf_init(ctx, &dbuf);
+    if (nml == 0) {
+        dbuf_put(&dbuf, (const uint8_t *)mg, mgl);
+    } else if (mgl == 0) {
+        dbuf_put(&dbuf, (const uint8_t *)nm, nml);
+    } else {
+        dbuf_put(&dbuf, (const uint8_t *)nm, nml);
+        dbuf_putstr(&dbuf, ": ");
+        dbuf_put(&dbuf, (const uint8_t *)mg, mgl);
+    }
+    dbuf_putc(&dbuf, '\n');
+    dbuf_put(&dbuf, (const uint8_t *)frames_s, frames_len);
+    if (dbuf_error(&dbuf))
+        res = JS_EXCEPTION;
+    else
+        res = JS_NewStringLen(ctx, (const char *)dbuf.buf, dbuf.size);
+    dbuf_free(&dbuf);
+    if (name_s)
+        JS_FreeCString(ctx, name_s);
+    if (msg_s)
+        JS_FreeCString(ctx, msg_s);
+    JS_FreeValue(ctx, name_v);
+    JS_FreeValue(ctx, msg_v);
+    JS_FreeCString(ctx, frames_s);
+    JS_FreeValue(ctx, frames_v);
+    return res;
+}
