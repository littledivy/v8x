+/* Keep async frames structured while an embedder prepare-stack callback is
+   pending. This lets the embedder process the complete frame list (including
+   source mapping) when Error.stack is eventually read. */
+static bool js_v82jsc_append_pending_async_callsite(JSContext *ctx,
+                                                    JSValueConst stack,
+                                                    const char *file,
+                                                    int line, int col,
+                                                    const char *func)
+{
+    JSValue len_v, site;
+    uint32_t next_idx = 0;
+
+    if (!js_error_stack_is_pending(ctx, stack))
+        return false;
+    len_v = JS_GetPropertyStr(ctx, stack, "length");
+    if (JS_ToUint32(ctx, &next_idx, len_v) < 0) {
+        JS_FreeValue(ctx, len_v);
+        JS_FreeValue(ctx, JS_GetException(ctx));
+        return false;
+    }
+    JS_FreeValue(ctx, len_v);
+    site = js_v82jsc_make_async_callsite(ctx, file, line, col, func, -1);
+    if (JS_IsNull(site))
+        return false;
+    if (JS_DefinePropertyValueUint32(ctx, stack, next_idx, site,
+                                     JS_PROP_C_W_E) < 0) {
+        JS_FreeValue(ctx, JS_GetException(ctx));
+        return false;
+    }
+    return true;
+}
