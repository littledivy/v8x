+bool v82jsc_weak_ref_is_live(JSValueConst weak_ref)
+{
+    JSWeakRefData *wrd = JS_GetOpaque(weak_ref, JS_CLASS_WEAK_REF);
+    return wrd && wrd != &js_weakref_sentinel;
+}
