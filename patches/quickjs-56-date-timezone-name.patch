+/* Return the local time zone abbreviation for a timestamp. */
+static size_t getTimezoneName(int64_t time, char *buf, size_t buf_size) {
+    time_t ti;
+    struct tm tm;
+
+    time /= 1000; /* convert to seconds */
+    if (sizeof(time_t) == 4) {
+        if ((time_t)-1 < 0) {
+            if (time < INT32_MIN) {
+                time = INT32_MIN;
+            } else if (time > INT32_MAX) {
+                time = INT32_MAX;
+            }
+        } else {
+            if (time < 0) {
+                time = 0;
+            } else if (time > UINT32_MAX) {
+                time = UINT32_MAX;
+            }
+        }
+    }
+    ti = time;
+#if defined(_WIN32)
+    if (localtime_s(&tm, &ti) != 0)
+        return 0;
+#else
+    if (!localtime_r(&ti, &tm))
+        return 0;
+#endif
+    return strftime(buf, buf_size, "%Z", &tm);
+}
