+static JSAtom js_error_stack_pending_atom(JSContext *ctx)
+{
+    JSAtom descr, atom;
+
+    if (JS_IsUndefined(ctx->error_stack_pending_marker)) {
+        descr = JS_NewAtom(ctx, "v82jsc.errorStackPending");
+        if (descr == JS_ATOM_NULL)
+            return JS_ATOM_NULL;
+        ctx->error_stack_pending_marker =
+            JS_NewSymbolFromAtom(ctx, descr, JS_ATOM_TYPE_PRIVATE);
+        JS_FreeAtom(ctx, descr);
+        if (JS_IsException(ctx->error_stack_pending_marker)) {
+            ctx->error_stack_pending_marker = JS_UNDEFINED;
+            return JS_ATOM_NULL;
+        }
+    }
+    atom = JS_ValueToAtom(ctx, ctx->error_stack_pending_marker);
+    return atom;
+}
+
+static bool js_mark_error_stack_pending(JSContext *ctx, JSValueConst stack)
+{
+    JSAtom atom = js_error_stack_pending_atom(ctx);
+    int ret;
+
+    if (atom == JS_ATOM_NULL)
+        return false;
+    ret = JS_DefinePropertyValue(ctx, stack, atom, JS_TRUE, 0);
+    JS_FreeAtom(ctx, atom);
+    return ret >= 0;
+}
+
+static bool js_error_stack_is_pending(JSContext *ctx, JSValueConst stack)
+{
+    JSAtom atom = js_error_stack_pending_atom(ctx);
+    int ret;
+
+    if (!JS_IsObject(stack))
+        return false;
+    if (atom == JS_ATOM_NULL)
+        return false;
+    ret = JS_HasProperty(ctx, stack, atom);
+    JS_FreeAtom(ctx, atom);
+    return ret > 0;
+}
+
+static void js_clear_error_stack_pending(JSContext *ctx, JSValueConst stack)
+{
+    JSAtom atom = js_error_stack_pending_atom(ctx);
+
+    if (atom == JS_ATOM_NULL)
+        return;
+    JS_DeleteProperty(ctx, stack, atom, 0);
+    JS_FreeAtom(ctx, atom);
+}
