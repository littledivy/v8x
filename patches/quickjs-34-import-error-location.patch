+static void js_resolve_import_throw_error(JSContext *ctx,
+                                          JSResolveResultEnum res,
+                                          JSModuleDef *importer,
+                                          const JSImportEntry *mi)
+{
+    const char *specifier;
+    const char *export_name;
+    JSValue exception;
 
+    if (res != JS_RESOLVE_RES_NOT_FOUND) {
+        JSModuleDef *target =
+            importer->req_module_entries[mi->req_module_idx].module;
+        js_resolve_export_throw_error(ctx, res, target, mi->import_name);
+        return;
+    }
+
+    specifier = JS_AtomToCString(
+        ctx, importer->req_module_entries[mi->req_module_idx].module_name);
+    export_name = JS_AtomToCString(ctx, mi->import_name);
+    if (specifier && export_name) {
+        JS_ThrowSyntaxError(
+            ctx,
+            "The requested module '%s' does not provide an export named '%s'",
+            specifier, export_name);
+        exception = JS_GetException(ctx);
+        JS_SetPropertyStr(ctx, exception, "fileName",
+                          JS_AtomToString(ctx, importer->module_name));
+        JS_Throw(ctx, exception);
+    }
+    if (specifier)
+        JS_FreeCString(ctx, specifier);
+    if (export_name)
+        JS_FreeCString(ctx, export_name);
+}
