+void v82jsc_set_module_error_backtrace(JSContext *ctx,
+                                       JSValueConst error,
+                                       const char *filename,
+                                       int line,
+                                       int column)
+{
+    JSObject *p;
+
+    if (JS_VALUE_GET_TAG(error) == JS_TAG_OBJECT) {
+        p = JS_VALUE_GET_OBJ(error);
+        if (p->class_id == JS_CLASS_ERROR) {
+            JS_FreeValue(ctx, p->u.object_data);
+            p->u.object_data = JS_UNDEFINED;
+        }
+    }
+    JS_FreeValue(ctx, ctx->error_back_trace);
+    ctx->error_back_trace = JS_UNDEFINED;
+    JS_Throw(ctx, js_dup(error));
+    build_backtrace(ctx, error, JS_UNDEFINED, filename, line, column,
+                    JS_BACKTRACE_FLAG_SINGLE_LEVEL);
+    JS_FreeValue(ctx, JS_GetException(ctx));
+}
+
+int v82jsc_link_module(JSContext *ctx, JSModuleDef *m)
+{
+    if (!m)
+        return -1;
+    if (m->status == JS_MODULE_STATUS_LINKED ||
+        m->status == JS_MODULE_STATUS_EVALUATING ||
+        m->status == JS_MODULE_STATUS_EVALUATING_ASYNC ||
+        m->status == JS_MODULE_STATUS_EVALUATED)
+        return 0;
+    if (js_create_module_function(ctx, m) < 0)
+        return -1;
+    if (js_link_module(ctx, m) < 0)
+        return -1;
+    return 0;
+}
