+static void js_v82jsc_append_promise_all_frame(JSContext *ctx,
+                                                JSValueConst error,
+                                                int index)
+{
+    JSValue stack, new_stack;
+    JSObject *error_obj;
+    JSShapeProperty *stack_prop;
+    DynBuf dbuf;
+    const char *cs;
+    size_t len;
+
+    if (JS_VALUE_GET_TAG(error) != JS_TAG_OBJECT)
+        return;
+    error_obj = JS_VALUE_GET_OBJ(error);
+    stack_prop = find_own_property1(error_obj, JS_ATOM_stack);
+    if (stack_prop && (stack_prop->flags & JS_PROP_TMASK) == JS_PROP_GETSET)
+        return;
+    stack = JS_GetProperty(ctx, error, JS_ATOM_stack);
+    if (JS_IsException(stack)) {
+        JS_FreeValue(ctx, JS_GetException(ctx));
+        return;
+    }
+    js_dbuf_init(ctx, &dbuf);
+    if (JS_IsString(stack)) {
+        cs = JS_ToCStringLen(ctx, &len, stack);
+        if (cs) {
+            dbuf_put(&dbuf, (const uint8_t *)cs, len);
+            if (len == 0 || cs[len - 1] != '\n')
+                dbuf_putc(&dbuf, '\n');
+            JS_FreeCString(ctx, cs);
+        }
+    }
+    JS_FreeValue(ctx, stack);
+    dbuf_printf(&dbuf, "    at async Promise.all (index %d)", index);
+    if (dbuf_error(&dbuf)) {
+        dbuf_free(&dbuf);
+        return;
+    }
+    new_stack = JS_NewStringLen(ctx, (const char *)dbuf.buf, dbuf.size);
+    dbuf_free(&dbuf);
+    if (JS_IsException(new_stack)) {
+        JS_FreeValue(ctx, JS_GetException(ctx));
+        return;
+    }
+    if (error_obj->class_id == JS_CLASS_ERROR && !stack_prop) {
+        JS_FreeValue(ctx, error_obj->u.object_data);
+        error_obj->u.object_data = new_stack;
+    } else if (JS_DefinePropertyValue(ctx, error, JS_ATOM_stack, new_stack,
+                                      JS_PROP_WRITABLE |
+                                      JS_PROP_CONFIGURABLE) < 0) {
+        JS_FreeValue(ctx, JS_GetException(ctx));
+    }
+
+    JSAtom key_atom = js_v82jsc_private_atom(ctx,
+        "v82jsc_private:deno_core::call_site_evals");
+    if (key_atom != JS_ATOM_NULL) {
+        JSValue existing = JS_GetProperty(ctx, error, key_atom);
+        JSValue arr;
+        uint32_t next_idx = 0;
+        if (JS_IsArray(existing)) {
+            arr = existing;
+            JSValue len_v = JS_GetPropertyStr(ctx, arr, "length");
+            JS_ToUint32(ctx, &next_idx, len_v);
+            JS_FreeValue(ctx, len_v);
+        } else {
+            JS_FreeValue(ctx, existing);
+            arr = JS_NewArray(ctx);
+        }
+        if (!JS_IsException(arr)) {
+            JSValue callsite =
+                js_v82jsc_make_async_callsite(ctx, NULL, 0, 0, NULL, index);
+            if (!JS_IsNull(callsite))
+                JS_DefinePropertyValueUint32(ctx, arr, next_idx, callsite,
+                                             JS_PROP_C_W_E);
+            if (JS_DefinePropertyValue(ctx, error, key_atom, arr,
+                                       JS_PROP_C_W_E) < 0)
+                JS_FreeValue(ctx, JS_GetException(ctx));
+        } else {
+            JS_FreeValue(ctx, JS_GetException(ctx));
+        }
+        JS_FreeAtom(ctx, key_atom);
+    }
+}
