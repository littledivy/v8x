+static int JS_WriteFunctionSource(BCWriterState *s,
+                                  const JSFunctionBytecode *b)
+{
+    uint32_t hash;
+    int i;
+
+    if (!s->allow_source || !b->source || b->source_len <= 0) {
+        bc_put_leb128(s, 0);
+        return 0;
+    }
+    hash = bc_csum((const uint8_t *)b->source, b->source_len);
+    for (i = 0; i < s->source_count; i++) {
+        BCSourceEntry *entry = &s->source_tab[i];
+        if (entry->len == (uint32_t)b->source_len &&
+            entry->hash == hash &&
+            !memcmp(entry->data, b->source, b->source_len)) {
+            /* 2+n references table entry n. */
+            bc_put_leb128(s, i + 2);
+            return 0;
+        }
+    }
+    if (js_resize_array(s->ctx, (void **)&s->source_tab,
+                        sizeof(s->source_tab[0]), &s->source_size,
+                        s->source_count + 1))
+        return -1;
+    s->source_tab[s->source_count++] = (BCSourceEntry) {
+        .data = (const uint8_t *)b->source,
+        .len = (uint32_t)b->source_len,
+        .hash = hash,
+    };
+    /* 1 introduces the next table entry. */
+    bc_put_leb128(s, 1);
+    bc_put_leb128(s, b->source_len);
+    dbuf_put(&s->dbuf, (const uint8_t *)b->source, b->source_len);
+    return 0;
+}
