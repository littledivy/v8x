+/* v82jsc: expose the hidden object QuickJS uses for global lexical
+   declarations (`let`/`const`). The snapshot shim serializes this separately
+   from the global object so restored contexts keep lexical bindings. */
+JSValue v82jsc_global_var_obj(JSContext *ctx) {
+    if (!ctx)
+        return JS_UNDEFINED;
+    return js_dup(ctx->global_var_obj);
+}
