+void v82jsc_mark_skip_next_async_frame(JSContext *ctx, JSValueConst error,
+                                       JSValueConst filename)
+{
+    JSAtom atom;
+
+    if (JS_VALUE_GET_TAG(error) != JS_TAG_OBJECT)
+        return;
+    atom = js_v82jsc_private_atom(ctx,
+        "v82jsc_private:skip_next_async_frame");
+    if (atom == JS_ATOM_NULL)
+        return;
+    if (JS_DefinePropertyValue(ctx, error, atom, js_dup(filename),
+                               JS_PROP_CONFIGURABLE) < 0)
+        JS_FreeValue(ctx, JS_GetException(ctx));
+    JS_FreeAtom(ctx, atom);
+}
+
+static bool js_v82jsc_take_skip_next_async_frame(JSContext *ctx,
+                                                  JSValueConst error,
+                                                  const char *file)
+{
+    JSAtom atom;
+    JSValue marker;
+    const char *marked_file;
+    bool skip;
+
+    atom = js_v82jsc_private_atom(ctx,
+        "v82jsc_private:skip_next_async_frame");
+    if (atom == JS_ATOM_NULL)
+        return false;
+    marker = JS_GetProperty(ctx, error, atom);
+    if (JS_IsException(marker)) {
+        JS_FreeValue(ctx, JS_GetException(ctx));
+        JS_FreeAtom(ctx, atom);
+        return false;
+    }
+    marked_file = JS_IsString(marker) ? JS_ToCString(ctx, marker) : NULL;
+    skip = marked_file && file && !strcmp(marked_file, file);
+    if (marked_file)
+        JS_FreeCString(ctx, marked_file);
+    JS_FreeValue(ctx, marker);
+    if (skip && JS_DeleteProperty(ctx, error, atom, 0) < 0)
+        JS_FreeValue(ctx, JS_GetException(ctx));
+    JS_FreeAtom(ctx, atom);
+    return skip;
+}
