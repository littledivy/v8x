+static const uint8_t js_coverage_magic[8] = {
+    'v', '8', 'x', '-', 'c', 'o', 'v', 0
+};
 
+static const uint8_t *js_coverage_data(JSFunctionBytecode *b,
+                                       uint32_t *count)
+{
+    const uint8_t *buf = b->pc2line_buf;
+    size_t len = b->pc2line_len;
+    size_t offset;
+
+    if (!buf || len < 12)
+        return NULL;
+    offset = len - 12;
+    for (;;) {
+        if (!memcmp(buf + offset, js_coverage_magic,
+                    sizeof(js_coverage_magic))) {
+            uint32_t n = get_u32(buf + offset + sizeof(js_coverage_magic));
+            if (offset + 12 + (size_t)n * 12 == len) {
+                *count = n;
+                return buf + offset;
+            }
+        }
+        if (offset == 0)
+            break;
+        offset--;
+    }
+    return NULL;
+}
