+    v82jsc_precise_coverage_enabled = enabled;
+}
+
+static void js_coverage_register_function(JSFunctionBytecode *b)
+{
+    const uint8_t *p, *p_end;
+    const char *function_name = "";
+    const char *filename = "";
+    bool free_function_name = false;
+    bool free_filename = false;
+    int line_num, column_num, pc, value, ret;
+    unsigned int op;
+
+    if (b->func_name != JS_ATOM_NULL) {
+        function_name = JS_AtomToCString(b->realm, b->func_name);
+        free_function_name = function_name != NULL;
+    }
+    if (b->filename != JS_ATOM_NULL) {
+        filename = JS_AtomToCString(b->realm, b->filename);
+        free_filename = filename != NULL;
+    }
+    v82jsc_coverage_function(b, function_name ? function_name : "",
+                             filename ? filename : "", b->source,
+                             b->source_len, b->line_num, b->col_num);
+    if (free_function_name)
+        JS_FreeCString(b->realm, function_name);
+    if (free_filename)
+        JS_FreeCString(b->realm, filename);
+
+    line_num = b->line_num;
+    column_num = b->col_num;
+    v82jsc_coverage_location(b, line_num, column_num);
+    p = b->pc2line_buf;
+    if (!p)
+        return;
+    p_end = p + b->pc2line_len;
+    pc = 0;
+    while (p < p_end) {
+        op = *p++;
+        if (op == 0) {
+            uint32_t pc_delta;
+            ret = get_leb128(&pc_delta, p, p_end);
+            if (ret < 0)
+                return;
+            pc += pc_delta;
+            p += ret;
+            ret = get_sleb128(&value, p, p_end);
+            if (ret < 0)
+                return;
+            p += ret;
+            line_num += value;
+        } else {
+            op -= PC2LINE_OP_FIRST;
+            pc += op / PC2LINE_RANGE;
+            line_num += (op % PC2LINE_RANGE) + PC2LINE_BASE;
+        }
+        ret = get_sleb128(&value, p, p_end);
+        if (ret < 0)
+            return;
+        p += ret;
+        column_num += value;
+        v82jsc_coverage_location(b, line_num, column_num);
+    }
 }
 
+static inline void js_coverage_record_hit(JSFunctionBytecode *b,
+                                          uint32_t pc)
+{
+    int column_num;
+    int line_num = find_line_num(b->realm, b, pc, &column_num);
+    v82jsc_coverage_hit(b, pc, line_num, column_num);
+}
