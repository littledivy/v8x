+static int emit_coverage(JSParseState *s, uint32_t start)
+{
+    int pos = s->cur_func->byte_code.size;
+    emit_op(s, OP_coverage);
+    emit_u32(s, start);
+    emit_u32(s, 0);
+    return pos;
+}
+
+static void close_coverage(JSParseState *s, int pos, uint32_t end)
+{
+    put_u32(s->cur_func->byte_code.buf + pos + 5, end);
+}
