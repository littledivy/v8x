+/* v82jsc: fired after any successful linear-memory grow (opcode OR host API), so
+ * the embedder can detach external ArrayBuffers it exposed to JS over the old,
+ * shorter size. wasm-bindgen only refetches `memory.buffer` once its cached view
+ * reports byteLength 0 (detached); without this its cached view keeps the stale
+ * length and overruns → "RangeError: out of bound". */
+typedef void (*v82jsc_mem_grow_cb_t)(void);
+static v82jsc_mem_grow_cb_t v82jsc_mem_grow_cb = NULL;
+void
+v82jsc_set_mem_grow_cb(v82jsc_mem_grow_cb_t cb)
+{
+    v82jsc_mem_grow_cb = cb;
+}
