+/* v82jsc: build a CallSite-shaped JS object for an injected async frame.
+   Used to satisfy embedders (e.g. deno's `has_call_site`) that gate stack
+   preservation on a populated `#callSiteEvals` private. Returns a fresh,
+   self-contained object; the embedder reads file/line/col via methods. */
+static JSValue js_v82jsc_make_async_callsite(JSContext *ctx, const char *file,
+                                             int line, int col)
+{
+    static const char src[] =
+        "(function(file, line, col) { return {\n"
+        "  getFileName: function () { return file; },\n"
+        "  getLineNumber: function () { return line; },\n"
+        "  getColumnNumber: function () { return col; },\n"
+        "  getFunctionName: function () { return null; },\n"
+        "  getMethodName: function () { return null; },\n"
+        "  getTypeName: function () { return null; },\n"
+        "  getEvalOrigin: function () { return null; },\n"
+        "  getPromiseIndex: function () { return null; },\n"
+        "  isToplevel: function () { return true; },\n"
+        "  isEval: function () { return false; },\n"
+        "  isNative: function () { return false; },\n"
+        "  isConstructor: function () { return false; },\n"
+        "  isAsync: function () { return true; },\n"
+        "  isPromiseAll: function () { return false; },\n"
+        "}; })";
+    JSValue factory = JS_Eval(ctx, src, sizeof(src) - 1,
+                              "<v82jsc-async-callsite>", JS_EVAL_TYPE_GLOBAL);
+    if (JS_IsException(factory))
+        return JS_NULL;
+    JSValue argv[3];
+    argv[0] = JS_NewString(ctx, file ? file : "");
+    argv[1] = js_int32(line);
+    argv[2] = js_int32(col);
+    JSValue cs = JS_Call(ctx, factory, JS_UNDEFINED, 3, vc(argv));
+    JS_FreeValue(ctx, factory);
+    JS_FreeValue(ctx, argv[0]);
+    if (JS_IsException(cs)) {
+        JS_FreeValue(ctx, JS_GetException(ctx));
+        return JS_NULL;
+    }
+    return cs;
+}
