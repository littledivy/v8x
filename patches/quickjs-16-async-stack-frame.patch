+/* v82jsc: append "    at async <file>:<line>:<col>" to the error's stack
+   property so an unhandled rejection propagating through an async function's
+   await surfaces the awaiting frame (V8-style async stack stitching). Also
+   appends a synthetic CallSite to the embedder's `#callSiteEvals` private so
+   gates like deno's `has_call_site` (which would otherwise rebuild a fresh
+   stack-less exception through `catch_dynamic_import_promise_error`) see a
+   populated structured-frames array and preserve the augmented stack.
+   No-op for non-object errors and when stack/file are absent. */
+static void js_v82jsc_append_async_frame(JSContext *ctx, JSValueConst error,
+                                         const char *file, int line, int col)
+{
+    JSValue stack, new_stack;
+    DynBuf dbuf;
+    const char *cs;
+    size_t len;
+
+    if (!file || JS_VALUE_GET_TAG(error) != JS_TAG_OBJECT)
+        return;
+    if (js_v82jsc_has_same_async_site(ctx, error, file, line))
+        return;
+    stack = JS_GetProperty(ctx, error, JS_ATOM_stack);
+    if (JS_IsException(stack)) {
+        JS_FreeValue(ctx, JS_GetException(ctx));
+        return;
+    }
+    js_dbuf_init(ctx, &dbuf);
+    if (JS_IsString(stack)) {
+        cs = JS_ToCStringLen(ctx, &len, stack);
+        if (cs) {
+            dbuf_put(&dbuf, (const uint8_t *)cs, len);
+            if (len == 0 || cs[len - 1] != '\n')
+                dbuf_putc(&dbuf, '\n');
+            JS_FreeCString(ctx, cs);
+        }
+    }
+    JS_FreeValue(ctx, stack);
+    dbuf_printf(&dbuf, "    at async %s", file);
+    if (line >= 1) {
+        dbuf_printf(&dbuf, ":%d", line);
+        if (col >= 1)
+            dbuf_printf(&dbuf, ":%d", col);
+    }
+    if (dbuf_error(&dbuf)) {
+        dbuf_free(&dbuf);
+        return;
+    }
+    new_stack = JS_NewStringLen(ctx, (const char *)dbuf.buf, dbuf.size);
+    dbuf_free(&dbuf);
+    if (JS_IsException(new_stack)) {
+        JS_FreeValue(ctx, JS_GetException(ctx));
+        return;
+    }
+    /* Install as an own data property; shadows js_error_get_stack so the
+       header isn't re-prepended (our string already carries it via the
+       prior accessor read). */
+    if (JS_DefinePropertyValue(ctx, error, JS_ATOM_stack, new_stack,
+                               JS_PROP_WRITABLE | JS_PROP_CONFIGURABLE) < 0) {
+        JS_FreeValue(ctx, JS_GetException(ctx));
+    }
+
+    /* Mirror the frame into the embedder's structured-frames array so
+       deno's `has_call_site` returns true and `catch_dynamic_import_promise_error`
+       rethrows the original (with our augmented stack) instead of building a
+       fresh stack-less exception. Best-effort — failures are swallowed since
+       a missing entry only degrades to the pre-patch behavior. */
+    JSAtom key_atom = js_v82jsc_private_atom(ctx,
+        "v82jsc_private:deno_core::call_site_evals");
+    if (key_atom != JS_ATOM_NULL) {
+        JSValue existing = JS_GetProperty(ctx, error, key_atom);
+        JSValue arr;
+        uint32_t next_idx = 0;
+        if (JS_IsArray(existing)) {
+            arr = existing;
+            JSValue len_v = JS_GetPropertyStr(ctx, arr, "length");
+            JS_ToUint32(ctx, &next_idx, len_v);
+            JS_FreeValue(ctx, len_v);
+        } else {
+            JS_FreeValue(ctx, existing);
+            arr = JS_NewArray(ctx);
+            if (JS_IsException(arr)) {
+                JS_FreeValue(ctx, JS_GetException(ctx));
+                JS_FreeAtom(ctx, key_atom);
+                return;
+            }
+        }
+        JSValue cs_obj = js_v82jsc_make_async_callsite(ctx, file, line, col);
+        if (!JS_IsNull(cs_obj)) {
+            JS_DefinePropertyValueUint32(ctx, arr, next_idx, cs_obj,
+                                         JS_PROP_C_W_E);
+        }
+        /* Stash the array back as the private property. */
+        if (JS_DefinePropertyValue(ctx, error, key_atom, arr,
+                                   JS_PROP_C_W_E) < 0) {
+            JS_FreeValue(ctx, JS_GetException(ctx));
+        }
+        JS_FreeAtom(ctx, key_atom);
+    }
+}
