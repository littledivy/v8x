+/* v82jsc: look up (or create) the embedder's private-symbol key for the
+   structured-frames array. deno uses `Symbol.for("v82jsc_private:<name>")`
+   via the shim's v8__Private__ForApi; we mirror that here so the same atom
+   is shared. Returns JS_ATOM_NULL on failure. */
+static JSAtom js_v82jsc_private_atom(JSContext *ctx, const char *name)
+{
+    JSValue global = JS_GetGlobalObject(ctx);
+    JSValue symbol_ctor = JS_GetPropertyStr(ctx, global, "Symbol");
+    JS_FreeValue(ctx, global);
+    if (!JS_IsObject(symbol_ctor)) {
+        JS_FreeValue(ctx, symbol_ctor);
+        return JS_ATOM_NULL;
+    }
+    JSValue symbol_for = JS_GetPropertyStr(ctx, symbol_ctor, "for");
+    if (!JS_IsFunction(ctx, symbol_for)) {
+        JS_FreeValue(ctx, symbol_for);
+        JS_FreeValue(ctx, symbol_ctor);
+        return JS_ATOM_NULL;
+    }
+    JSValue arg = JS_NewString(ctx, name);
+    JSValue sym = JS_Call(ctx, symbol_for, symbol_ctor, 1, vc(&arg));
+    JS_FreeValue(ctx, arg);
+    JS_FreeValue(ctx, symbol_for);
+    JS_FreeValue(ctx, symbol_ctor);
+    if (JS_IsException(sym)) {
+        JS_FreeValue(ctx, JS_GetException(ctx));
+        return JS_ATOM_NULL;
+    }
+    JSAtom atom = JS_ValueToAtom(ctx, sym);
+    JS_FreeValue(ctx, sym);
+    return atom;
+}
