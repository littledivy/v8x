+static bool js_v82jsc_has_same_async_site(JSContext *ctx,
+                                           JSValueConst error,
+                                           const char *file, int line)
+{
+    JSAtom key_atom;
+    JSValue existing, site, method, file_value, line_value;
+    const char *site_file;
+    int32_t site_line = 0;
+    bool same = false;
+
+    key_atom = js_v82jsc_private_atom(ctx,
+        "v82jsc_private:deno_core::call_site_evals");
+    if (key_atom == JS_ATOM_NULL)
+        return false;
+    existing = JS_GetProperty(ctx, error, key_atom);
+    JS_FreeAtom(ctx, key_atom);
+    if (!JS_IsArray(existing)) {
+        JS_FreeValue(ctx, existing);
+        return false;
+    }
+    site = JS_GetPropertyUint32(ctx, existing, 0);
+    JS_FreeValue(ctx, existing);
+    if (!JS_IsObject(site)) {
+        JS_FreeValue(ctx, site);
+        return false;
+    }
+    method = JS_GetPropertyStr(ctx, site, "getFileName");
+    file_value = JS_IsFunction(ctx, method)
+        ? JS_Call(ctx, method, site, 0, NULL) : JS_UNDEFINED;
+    JS_FreeValue(ctx, method);
+    method = JS_GetPropertyStr(ctx, site, "getLineNumber");
+    line_value = JS_IsFunction(ctx, method)
+        ? JS_Call(ctx, method, site, 0, NULL) : JS_UNDEFINED;
+    JS_FreeValue(ctx, method);
+    JS_FreeValue(ctx, site);
+    site_file = JS_ToCString(ctx, file_value);
+    if (site_file && JS_ToInt32(ctx, &site_line, line_value) == 0)
+        same = !strcmp(site_file, file) && site_line == line;
+    if (site_file)
+        JS_FreeCString(ctx, site_file);
+    JS_FreeValue(ctx, file_value);
+    JS_FreeValue(ctx, line_value);
+    if (JS_HasException(ctx))
+        JS_FreeValue(ctx, JS_GetException(ctx));
+    return same;
+}
