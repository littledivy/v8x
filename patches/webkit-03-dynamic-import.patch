+// v82jsc: JS `import(specifier)` lands here. The plain C-API global object has
+// no module loader, so route to deno's HostImportModuleDynamicallyCallback
+// (via the Rust shim) and return its promise — deno resolves/fetches/evaluates
+// the module and settles the promise with the namespace.
+JSPromise* JSAPIGlobalObject::moduleLoaderImportModule(JSGlobalObject* globalObject, JSModuleLoader*, JSString* specifierValue, RefPtr<ScriptFetchParameters> attributes, const SourceOrigin& sourceOrigin, bool)
+{
+    VM& vm = globalObject->vm();
+    auto scope = DECLARE_THROW_SCOPE(vm);
+    auto reject = [&] (const String& message) -> JSPromise* {
+        auto* promise = JSPromise::create(vm, globalObject->promiseStructure());
+        promise->reject(vm, createError(globalObject, message));
+        return promise;
+    };
+
+    if (!v82jsc_dynamic_import)
+        return reject("dynamic import: no host module loader"_s);
+
+    String specifier = specifierValue->value(globalObject);
+    RETURN_IF_EXCEPTION(scope, reject("invalid import specifier"_s));
+    String referrer = sourceOrigin.string();
+
+    JSGlobalContextRef ctx = toGlobalRef(globalObject);
+    JSStringRef specRef = JSStringCreateWithUTF8CString(specifier.utf8().data());
+    JSStringRef refRef = referrer.isNull() ? nullptr : JSStringCreateWithUTF8CString(referrer.utf8().data());
+    int attrType = attributes ? static_cast<int>(attributes->type()) : 0;
+
+    JSValueRef promiseRef = v82jsc_dynamic_import(ctx, specRef, refRef, attrType);
+
+    JSStringRelease(specRef);
+    if (refRef)
+        JSStringRelease(refRef);
+
+    if (!promiseRef)
+        return reject("dynamic import: no host module loader"_s);
+
+    JSValue promiseValue = toJS(globalObject, promiseRef);
+    if (promiseValue.isObject())
+        return static_cast<JSPromise*>(asObject(promiseValue));
+    return reject("dynamic import: host did not return a promise"_s);
+}
+
+// v82jsc: a native module's `import.meta`. Route to deno's import-meta callback
+// (via the Rust shim) which sets url/main/resolve; fall back to an empty object.
+JSObject* JSAPIGlobalObject::moduleLoaderCreateImportMetaProperties(JSGlobalObject* globalObject, JSModuleLoader*, JSValue key, JSModuleRecord* moduleRecord, RefPtr<ScriptFetcher>)
+{
+    JSObject* empty = constructEmptyObject(globalObject->vm(), globalObject->nullPrototypeObjectStructure());
+    if (!v82jsc_create_import_meta)
+        return empty;
+
+    String keyStr = key.isString() ? asString(key)->value(globalObject) : String();
+    JSGlobalContextRef ctx = toGlobalRef(globalObject);
+    JSStringRef keyRef = keyStr.isNull() ? nullptr : JSStringCreateWithUTF8CString(keyStr.utf8().data());
+
+    JSValueRef metaRef = v82jsc_create_import_meta(ctx, static_cast<void*>(moduleRecord), keyRef);
+    if (keyRef)
+        JSStringRelease(keyRef);
+
+    if (!metaRef)
+        return empty;
+    JSValue metaValue = toJS(globalObject, metaRef);
+    if (metaValue.isObject())
+        return asObject(metaValue);
+    return empty;
+}
+
 #endif
 
