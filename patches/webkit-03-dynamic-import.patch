+// v82jsc: routes import() to deno's HostImportModuleDynamicallyCallback (the
+// real impl is #[no_mangle] in the Rust shim and overrides this at link). This
+// WEAK DEFINITION (returns null) lets JSC's own tools (jsc CLI, etc.) that link
+// libJavaScriptCore.a WITHOUT the Rust shim still resolve the symbol; the null
+// is handled by the caller. deno's strong Rust definition wins in the binary.
+extern "C" __attribute__((weak)) JSValueRef v82jsc_dynamic_import(JSContextRef, JSStringRef, JSStringRef, int)
+{
+    return nullptr;
+}
+
+// v82jsc: routes a native module's `import.meta` to deno's
+// HostInitializeImportMetaObject callback (real impl #[no_mangle] in the Rust
+// shim). Weak null fallback so the jsc CLI links without the shim. `record` is
+// the raw AbstractModuleRecord* (key for the Rust record->Module map); `key` is
+// the module key string (the URL).
+extern "C" __attribute__((weak)) JSValueRef v82jsc_create_import_meta(JSContextRef, void*, JSStringRef)
+{
+    return nullptr;
+}
