+static int JS_WriteVarRef(BCWriterState *s, JSVarRef *var_ref)
+{
+    int i;
+    uint8_t flags;
+
+    if (!var_ref || !var_ref->pvalue) {
+        JS_ThrowInternalError(s->ctx, "invalid closure variable");
+        return -1;
+    }
+    for (i = 0; i < s->var_ref_count; i++) {
+        if (s->var_ref_tab[i] == var_ref) {
+            bc_put_u8(s, 0);
+            bc_put_leb128(s, i);
+            return 0;
+        }
+    }
+    if (js_resize_array(s->ctx, (void **)&s->var_ref_tab,
+                        sizeof(s->var_ref_tab[0]), &s->var_ref_size,
+                        s->var_ref_count + 1))
+        return -1;
+    s->var_ref_tab[s->var_ref_count++] = var_ref;
+
+    bc_put_u8(s, 1);
+    flags = var_ref->is_lexical | (var_ref->is_const << 1);
+    bc_put_u8(s, flags);
+    return JS_WriteObjectRec(s, *var_ref->pvalue);
+}
