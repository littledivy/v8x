+static int JS_WriteBytecodeFunctionObject(BCWriterState *s,
+                                          JSValueConst obj)
+{
+    JSObject *p = JS_VALUE_GET_OBJ(obj);
+    JSFunctionBytecode *b = p->u.func.function_bytecode;
+    int i;
+
+    if (!s->allow_bytecode || !b)
+        goto invalid;
+    bc_put_u8(s, BC_TAG_BYTECODE_FUNCTION_OBJECT);
+    bc_put_u8(s, b->func_kind);
+    if (JS_WriteObjectRec(s, JS_MKPTR(JS_TAG_FUNCTION_BYTECODE, b)))
+        return -1;
+    bc_put_leb128(s, b->closure_var_count);
+    for (i = 0; i < b->closure_var_count; i++) {
+        if (JS_WriteVarRef(s, p->u.func.var_refs[i]))
+            return -1;
+    }
+    if (p->u.func.home_object) {
+        bc_put_u8(s, 1);
+        if (JS_WriteObjectRec(s,
+                              JS_MKPTR(JS_TAG_OBJECT,
+                                       p->u.func.home_object)))
+            return -1;
+    } else {
+        bc_put_u8(s, 0);
+    }
+    return JS_WriteSnapshotObjectState(s, obj);
+
+ invalid:
+    JS_ThrowTypeError(s->ctx, "invalid bytecode function object");
+    return -1;
+}
