+            desc.value = JS_UNDEFINED;
+            desc.getter = JS_UNDEFINED;
+            desc.setter = JS_UNDEFINED;
+            if (JS_GetOwnProperty(s->ctx, &desc, obj, atom) <= 0) {
+                JS_FreeAtom(s->ctx, atom);
+                atom = JS_ATOM_NULL;
+                goto fail;
+            }
+            JS_FreeAtom(s->ctx, atom);
+            atom = JS_ATOM_NULL;
+            next = kind == JS_INTRINSIC_VALUE ? desc.value :
+                (kind == JS_INTRINSIC_GETTER ? desc.getter : desc.setter);
