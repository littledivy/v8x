+/* Returns 1 when the embedder handled the object, 0 when it did not, and -1
+   on error. */
+static int JS_WriteHostObject(BCWriterState *s, JSValueConst obj)
+{
+    uint8_t *buf;
+    size_t size = 0, written;
+    int ret;
+
+    ret = v82jsc_snapshot_write_host_object(s->ctx, obj, NULL, &size);
+    if (ret <= 0)
+        return ret;
+    if (size > UINT32_MAX)
+        return -1;
+    buf = js_malloc(s->ctx, size);
+    if (!buf)
+        return -1;
+    written = size;
+    ret = v82jsc_snapshot_write_host_object(s->ctx, obj, buf, &written);
+    if (ret <= 0 || written != size) {
+        js_free(s->ctx, buf);
+        return -1;
+    }
+    bc_put_u8(s, BC_TAG_HOST_OBJECT);
+    bc_put_leb128(s, size);
+    dbuf_put(&s->dbuf, buf, size);
+    js_free(s->ctx, buf);
+    return 1;
+}
+
+#define JS_INTRINSIC_PATH_MAX 64
+#define JS_INTRINSIC_VALUE 0
+#define JS_INTRINSIC_GETTER 1
+#define JS_INTRINSIC_SETTER 2
+#define JS_INTRINSIC_PROTOTYPE 3
+
+typedef struct JSIntrinsicFunctionPath {
+    JSContext *ctx;
+    JSObjectList visited;
+    JSClassID target_class_id;
+    JSCFunction *target_function;
+    JSCFunctionData *target_function_data;
+    uint8_t target_length;
+    uint8_t target_cproto;
+    int16_t target_magic;
+    bool match_metadata;
+    bool found_exact;
+    uint8_t depth;
+    uint8_t kinds[JS_INTRINSIC_PATH_MAX];
+    JSAtom atoms[JS_INTRINSIC_PATH_MAX];
+    uint8_t found_len;
+    uint8_t found_kinds[JS_INTRINSIC_PATH_MAX];
+    JSAtom found_atoms[JS_INTRINSIC_PATH_MAX];
+} JSIntrinsicFunctionPath;
+
+static int JS_SearchIntrinsicFunctionPath(JSIntrinsicFunctionPath *s,
+                                          JSValueConst value)
+{
+    JSPropertyDescriptor desc;
+    JSPropertyEnum *props = NULL;
+    JSObject *p;
+    JSValue proto;
+    uint32_t len = 0, i;
+    int kind, ret = 0;
+
+    if (JS_VALUE_GET_TAG(value) != JS_TAG_OBJECT)
+        return 0;
+    p = JS_VALUE_GET_OBJ(value);
+    if ((s->target_class_id == JS_CLASS_C_FUNCTION &&
+         p->class_id == JS_CLASS_C_FUNCTION &&
+         p->u.cfunc.c_function.generic == s->target_function &&
+         (!s->match_metadata ||
+          (p->u.cfunc.length == s->target_length &&
+           p->u.cfunc.cproto == s->target_cproto &&
+           p->u.cfunc.magic == s->target_magic))) ||
+        (s->target_class_id == JS_CLASS_C_FUNCTION_DATA &&
+         p->class_id == JS_CLASS_C_FUNCTION_DATA &&
+         p->u.c_function_data_record &&
+         p->u.c_function_data_record->func == s->target_function_data)) {
+        s->found_len = s->depth;
+        for (i = 0; i < s->depth; i++) {
+            s->found_kinds[i] = s->kinds[i];
+            s->found_atoms[i] = s->kinds[i] == JS_INTRINSIC_PROTOTYPE ?
+                JS_ATOM_NULL : JS_DupAtom(s->ctx, s->atoms[i]);
+        }
+        return 1;
+    }
+    if (s->depth >= JS_INTRINSIC_PATH_MAX ||
+        js_object_list_find(s->ctx, &s->visited, p) >= 0)
+        return 0;
+    if (js_object_list_add(s->ctx, &s->visited, p))
+        return -1;
+
+    if (JS_GetOwnPropertyNames(s->ctx, &props, &len, value,
+                               JS_GPN_STRING_MASK | JS_GPN_SYMBOL_MASK) < 0)
+        goto done;
+    for (i = 0; i < len; i++) {
+        memset(&desc, 0, sizeof(desc));
+        desc.value = JS_UNDEFINED;
+        desc.getter = JS_UNDEFINED;
+        desc.setter = JS_UNDEFINED;
+        if (JS_GetOwnProperty(s->ctx, &desc, value, props[i].atom) < 0) {
+            ret = -1;
+            goto done;
+        }
+        for (kind = JS_INTRINSIC_VALUE; kind <= JS_INTRINSIC_SETTER; kind++) {
+            JSValue child = kind == JS_INTRINSIC_VALUE ? desc.value :
+                (kind == JS_INTRINSIC_GETTER ? desc.getter : desc.setter);
+            s->kinds[s->depth] = kind;
+            s->atoms[s->depth++] = props[i].atom;
+            ret = JS_SearchIntrinsicFunctionPath(s, child);
+            s->depth--;
+            if (ret != 0)
+                break;
+        }
+        JS_FreeValue(s->ctx, desc.value);
+        JS_FreeValue(s->ctx, desc.getter);
+        JS_FreeValue(s->ctx, desc.setter);
+        if (ret != 0)
+            goto done;
+    }
+    proto = p->shape->proto ?
+        JS_MKPTR(JS_TAG_OBJECT, p->shape->proto) : JS_NULL;
+    s->kinds[s->depth] = JS_INTRINSIC_PROTOTYPE;
+    s->atoms[s->depth++] = JS_ATOM_NULL;
+    ret = JS_SearchIntrinsicFunctionPath(s, proto);
+    s->depth--;
+
+ done:
+    if (props)
+        js_free_prop_enum(s->ctx, props, len);
+    return ret;
+}
+
+static int JS_FindIntrinsicFunctionPath(JSContext *ctx, JSValueConst value,
+                                        JSIntrinsicFunctionPath *path)
+{
+    JSObject *target = JS_VALUE_GET_OBJ(value);
+    JSValue global, registry;
+    JSAtom registry_atom;
+    int ret;
+
+    memset(path, 0, sizeof(*path));
+    path->ctx = ctx;
+    path->target_class_id = target->class_id;
+    if (target->class_id == JS_CLASS_C_FUNCTION) {
+        path->target_function = target->u.cfunc.c_function.generic;
+        path->target_length = target->u.cfunc.length;
+        path->target_cproto = target->u.cfunc.cproto;
+        path->target_magic = target->u.cfunc.magic;
+    } else if (target->class_id == JS_CLASS_C_FUNCTION_DATA &&
+               target->u.c_function_data_record) {
+        path->target_function_data = target->u.c_function_data_record->func;
+    } else {
+        return -1;
+    }
+    js_object_list_init(&path->visited);
+    global = JS_GetGlobalObject(ctx);
+    registry_atom = JS_NewAtom(ctx, "__v8x_snapshot_intrinsics");
+    registry = JS_GetProperty(ctx, global, registry_atom);
+    path->kinds[0] = JS_INTRINSIC_VALUE;
+    path->atoms[0] = registry_atom;
+    path->depth = 1;
+    path->match_metadata = true;
+    ret = JS_SearchIntrinsicFunctionPath(path, registry);
+    if (ret == 0 && path->target_class_id == JS_CLASS_C_FUNCTION) {
+        js_object_list_end(ctx, &path->visited);
+        js_object_list_init(&path->visited);
+        path->match_metadata = false;
+        ret = JS_SearchIntrinsicFunctionPath(path, registry);
+    }
+    path->found_exact = path->match_metadata && ret > 0;
+    path->depth = 0;
+    JS_FreeValue(ctx, registry);
+    JS_FreeAtom(ctx, registry_atom);
+    JS_FreeValue(ctx, global);
+    js_object_list_end(ctx, &path->visited);
+    return ret > 0 ? 0 : -1;
+}
+
+static void JS_FreeIntrinsicFunctionPath(JSIntrinsicFunctionPath *path)
+{
+    int i;
+    if (!path->ctx)
+        return;
+    for (i = 0; i < path->found_len; i++) {
+        if (path->found_kinds[i] != JS_INTRINSIC_PROTOTYPE)
+            JS_FreeAtom(path->ctx, path->found_atoms[i]);
+    }
+}
+
+static int JS_WriteCFunctionObject(BCWriterState *s, JSValueConst obj)
+{
+    JSObject *p = JS_VALUE_GET_OBJ(obj);
+    JSIntrinsicFunctionPath path;
+    JSValue value;
+    int i, ret;
+
+    memset(&path, 0, sizeof(path));
+    ret = JS_WriteHostObject(s, obj);
+    if (ret != 0)
+        return ret < 0 ? -1 : 0;
+    if (JS_FindIntrinsicFunctionPath(s->ctx, obj, &path)) {
+        const char *description;
+        JS_FreeIntrinsicFunctionPath(&path);
+        description = JS_ToCString(s->ctx, obj);
+        JS_ThrowTypeError(s->ctx, "unregistered native function: %s",
+                          description ? description : "<unknown>");
+        JS_FreeCString(s->ctx, description);
+        return -1;
+    }
+    bc_put_u8(s, BC_TAG_C_FUNCTION_OBJECT);
+    bc_put_leb128(s, path.found_len);
+    for (i = 0; i < path.found_len; i++) {
+        bc_put_u8(s, path.found_kinds[i]);
+        if (path.found_kinds[i] != JS_INTRINSIC_PROTOTYPE)
+            bc_put_atom(s, path.found_atoms[i]);
+    }
+    bc_put_u8(s, path.found_exact);
+    JS_FreeIntrinsicFunctionPath(&path);
+    if (path.found_exact)
+        return 0;
+
+    bc_put_u8(s, p->u.cfunc.length);
+    bc_put_u8(s, p->u.cfunc.cproto);
+    bc_put_u16(s, p->u.cfunc.magic);
+    value = JS_GetPrototype(s->ctx, obj);
+    if (JS_IsException(value))
+        return -1;
+    ret = JS_WriteObjectRec(s, value);
+    JS_FreeValue(s->ctx, value);
+    if (ret)
+        return -1;
+    value = JS_GetProperty(s->ctx, obj, JS_ATOM_length);
+    if (JS_IsException(value))
+        return -1;
+    ret = JS_WriteObjectRec(s, value);
+    JS_FreeValue(s->ctx, value);
+    if (ret)
+        return -1;
+    value = JS_GetProperty(s->ctx, obj, JS_ATOM_name);
+    if (JS_IsException(value))
+        return -1;
+    ret = JS_WriteObjectRec(s, value);
+    JS_FreeValue(s->ctx, value);
+    return ret;
+}
+
+static int JS_WriteCFunctionDataObject(BCWriterState *s, JSValueConst obj)
+{
+    JSObject *p = JS_VALUE_GET_OBJ(obj);
+    JSCFunctionDataRecord *record = p->u.c_function_data_record;
+    JSIntrinsicFunctionPath path;
+    JSValue value;
+    int i, ret;
+
+    memset(&path, 0, sizeof(path));
+    ret = JS_WriteHostObject(s, obj);
+    if (ret != 0)
+        return ret < 0 ? -1 : 0;
+    if (!record || JS_FindIntrinsicFunctionPath(s->ctx, obj, &path)) {
+        const char *description;
+        JS_FreeIntrinsicFunctionPath(&path);
+        description = JS_ToCString(s->ctx, obj);
+        JS_ThrowTypeError(s->ctx, "unregistered native closure: %s",
+                          description ? description : "<unknown>");
+        JS_FreeCString(s->ctx, description);
+        return -1;
+    }
+    bc_put_u8(s, BC_TAG_C_FUNCTION_DATA_OBJECT);
+    bc_put_leb128(s, path.found_len);
+    for (i = 0; i < path.found_len; i++) {
+        bc_put_u8(s, path.found_kinds[i]);
+        if (path.found_kinds[i] != JS_INTRINSIC_PROTOTYPE)
+            bc_put_atom(s, path.found_atoms[i]);
+    }
+    JS_FreeIntrinsicFunctionPath(&path);
+    bc_put_u8(s, record->length);
+    bc_put_u16(s, record->magic);
+    bc_put_leb128(s, record->data_len);
+    for (i = 0; i < record->data_len; i++) {
+        if (JS_WriteObjectRec(s, record->data[i]))
+            return -1;
+    }
+    value = JS_GetProperty(s->ctx, obj, JS_ATOM_length);
+    if (JS_IsException(value))
+        return -1;
+    ret = JS_WriteObjectRec(s, value);
+    JS_FreeValue(s->ctx, value);
+    if (ret)
+        return -1;
+    value = JS_GetProperty(s->ctx, obj, JS_ATOM_name);
+    if (JS_IsException(value))
+        return -1;
+    ret = JS_WriteObjectRec(s, value);
+    JS_FreeValue(s->ctx, value);
+    return ret;
+}
+
+static int JS_WriteBoundFunctionObject(BCWriterState *s,
+                                       JSValueConst obj)
+{
+    JSObject *p = JS_VALUE_GET_OBJ(obj);
+    JSBoundFunction *bf = p->u.bound_function;
+    JSValue value;
+    int i, ret;
+
+    bc_put_u8(s, BC_TAG_BOUND_FUNCTION_OBJECT);
+    bc_put_leb128(s, bf->argc);
+    if (JS_WriteObjectRec(s, bf->func_obj) ||
+        JS_WriteObjectRec(s, bf->this_val))
+        return -1;
+    for (i = 0; i < bf->argc; i++) {
+        if (JS_WriteObjectRec(s, bf->argv[i]))
+            return -1;
+    }
+    value = JS_GetProperty(s->ctx, obj, JS_ATOM_length);
+    if (JS_IsException(value))
+        return -1;
+    ret = JS_WriteObjectRec(s, value);
+    JS_FreeValue(s->ctx, value);
+    if (ret)
+        return -1;
+    value = JS_GetProperty(s->ctx, obj, JS_ATOM_name);
+    if (JS_IsException(value))
+        return -1;
+    ret = JS_WriteObjectRec(s, value);
+    JS_FreeValue(s->ctx, value);
+    return ret;
+}
+
+static int JS_WriteProxy(BCWriterState *s, JSValueConst obj)
+{
+    JSProxyData *proxy = JS_VALUE_GET_OBJ(obj)->u.proxy_data;
+
+    if (!proxy) {
+        JS_ThrowTypeError(s->ctx, "invalid proxy");
+        return -1;
+    }
+    bc_put_u8(s, BC_TAG_PROXY);
+    bc_put_u8(s, proxy->is_revoked);
+    if (JS_WriteObjectRec(s, proxy->target) ||
+        JS_WriteObjectRec(s, proxy->handler))
+        return -1;
+    return 0;
+}
