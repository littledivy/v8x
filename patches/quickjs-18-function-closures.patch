+static int JS_WriteModuleNamespace(BCWriterState *s, JSValueConst obj)
+{
+    JSObject *p = JS_VALUE_GET_OBJ(obj);
+    JSPropertyDescriptor desc;
+    JSPropertyEnum *props = NULL;
+    JSShapeProperty *shape_prop;
+    JSProperty *prop;
+    JSValue getter, setter;
+    uint32_t len = 0, i;
+    int ret = -1;
