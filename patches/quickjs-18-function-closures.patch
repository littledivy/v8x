+    if (bc_get_leb128(s, &len) || len > JS_INTRINSIC_PATH_MAX)
+        return JS_ThrowSyntaxError(s->ctx, "invalid intrinsic function path");
+    obj = JS_GetGlobalObject(s->ctx);
+    for (i = 0; i < len; i++) {
+        if (bc_get_u8(s, &kind))
+            goto fail;
