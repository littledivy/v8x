+typedef struct JSSnapshotIntrinsicCollector {
+    JSContext *ctx;
+    JSValue registry;
+    JSObject *registry_object;
+    JSObjectList visited;
+    uint32_t next_index;
+} JSSnapshotIntrinsicCollector;
+
+static void JS_CollectSnapshotIntrinsics(JSSnapshotIntrinsicCollector *s,
+                                         JSValueConst value, int depth)
+{
+    JSPropertyDescriptor desc;
+    JSPropertyEnum *props = NULL;
+    JSObject *p;
+    JSValue proto;
+    uint32_t len = 0, i;
+    int ret;
+
+    if (JS_VALUE_GET_TAG(value) != JS_TAG_OBJECT || depth > 64)
+        return;
+    p = JS_VALUE_GET_OBJ(value);
+    if (p == s->registry_object ||
+        js_object_list_find(s->ctx, &s->visited, p) >= 0)
+        return;
+    if (js_object_list_add(s->ctx, &s->visited, p))
+        return;
+
+    if (p->class_id == JS_CLASS_C_FUNCTION ||
+        p->class_id == JS_CLASS_C_FUNCTION_DATA) {
+        if (JS_SetPropertyUint32(s->ctx, s->registry, s->next_index++,
+                                 JS_DupValue(s->ctx, value)) < 0) {
+            JSValue exc = JS_GetException(s->ctx);
+            JS_FreeValue(s->ctx, exc);
+        }
+    }
+
+    ret = JS_GetOwnPropertyNames(s->ctx, &props, &len, value,
+                                 JS_GPN_STRING_MASK | JS_GPN_SYMBOL_MASK |
+                                 JS_GPN_PRIVATE_MASK);
+    if (ret < 0) {
+        JSValue exc = JS_GetException(s->ctx);
+        JS_FreeValue(s->ctx, exc);
+        goto proto;
+    }
+    for (i = 0; i < len; i++) {
+        memset(&desc, 0, sizeof(desc));
+        desc.value = JS_UNDEFINED;
+        desc.getter = JS_UNDEFINED;
+        desc.setter = JS_UNDEFINED;
+        ret = JS_GetOwnProperty(s->ctx, &desc, value, props[i].atom);
+        if (ret > 0) {
+            JS_CollectSnapshotIntrinsics(s, desc.value, depth + 1);
+            JS_CollectSnapshotIntrinsics(s, desc.getter, depth + 1);
+            JS_CollectSnapshotIntrinsics(s, desc.setter, depth + 1);
+            JS_FreeValue(s->ctx, desc.value);
+            JS_FreeValue(s->ctx, desc.getter);
+            JS_FreeValue(s->ctx, desc.setter);
+        } else if (ret < 0) {
+            JSValue exc = JS_GetException(s->ctx);
+            JS_FreeValue(s->ctx, exc);
+        }
+    }
+    js_free_prop_enum(s->ctx, props, len);
+
+ proto:
+    proto = p->shape->proto ?
+        JS_MKPTR(JS_TAG_OBJECT, p->shape->proto) : JS_NULL;
+    JS_CollectSnapshotIntrinsics(s, proto, depth + 1);
+}
+
+void v82jsc_snapshot_capture_intrinsics(JSContext *ctx, JSValue registry)
+{
+    JSSnapshotIntrinsicCollector s;
+    JSValue global;
+    int64_t length = 0;
+    uint32_t i;
+
+    if (!ctx || JS_VALUE_GET_TAG(registry) != JS_TAG_OBJECT)
+        return;
+    memset(&s, 0, sizeof(s));
+    s.ctx = ctx;
+    s.registry = registry;
+    s.registry_object = JS_VALUE_GET_OBJ(registry);
+    if (JS_GetLength(ctx, registry, &length) < 0 || length < 0 ||
+        length > UINT32_MAX) {
+        JSValue exc = JS_GetException(ctx);
+        JS_FreeValue(ctx, exc);
+        return;
+    }
+    s.next_index = length;
+    js_object_list_init(&s.visited);
+
+    global = JS_GetGlobalObject(ctx);
+    JS_CollectSnapshotIntrinsics(&s, global, 0);
+    JS_FreeValue(ctx, global);
+    JS_CollectSnapshotIntrinsics(&s, ctx->global_var_obj, 0);
+    JS_CollectSnapshotIntrinsics(&s, ctx->function_proto, 0);
+    JS_CollectSnapshotIntrinsics(&s, ctx->function_ctor, 0);
+    JS_CollectSnapshotIntrinsics(&s, ctx->array_ctor, 0);
+    JS_CollectSnapshotIntrinsics(&s, ctx->regexp_ctor, 0);
+    JS_CollectSnapshotIntrinsics(&s, ctx->promise_ctor, 0);
+    JS_CollectSnapshotIntrinsics(&s, ctx->error_ctor, 0);
+    JS_CollectSnapshotIntrinsics(&s, ctx->iterator_ctor, 0);
+    JS_CollectSnapshotIntrinsics(&s, ctx->iterator_proto, 0);
+    JS_CollectSnapshotIntrinsics(&s, ctx->async_iterator_proto, 0);
+    JS_CollectSnapshotIntrinsics(&s, ctx->throw_type_error, 0);
+    JS_CollectSnapshotIntrinsics(&s, ctx->eval_obj, 0);
+    for (i = 0; i < ctx->rt->class_count; i++)
+        JS_CollectSnapshotIntrinsics(&s, ctx->class_proto[i], 0);
+
+    js_object_list_end(ctx, &s.visited);
+}
