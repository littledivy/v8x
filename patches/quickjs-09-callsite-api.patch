+
+// v82jsc patch: the rest of V8's CallSite API. QuickJS-ng ships only
+// isNative/getFileName/getFunction/getFunctionName/get{Line,Column}Number, but
+// many npm packages (depd, stack-trace, source-map-support, ...) call the other
+// methods on the CallSite objects passed to a user `Error.prepareStackTrace`.
+static JSValue js_callsite_ret_undefined(JSContext *ctx, JSValueConst this_val, int argc, JSValueConst *argv)
+{
+    return JS_UNDEFINED;
+}
+
+static JSValue js_callsite_ret_null(JSContext *ctx, JSValueConst this_val, int argc, JSValueConst *argv)
+{
+    return JS_NULL;
+}
+
+static JSValue js_callsite_ret_false(JSContext *ctx, JSValueConst this_val, int argc, JSValueConst *argv)
+{
+    return js_bool(false);
+}
+
+// Read a data property without invoking getters or proxy traps. V8's CallSite
+// type-name lookup likewise ignores an accessor Symbol.toStringTag.
+static JSValue js_callsite_get_data_property(JSObject *p, JSAtom atom)
+{
+    while (p) {
+        JSProperty *pr;
+        JSShapeProperty *prs = find_own_property(&pr, p, atom);
+        if (prs) {
+            switch (prs->flags & JS_PROP_TMASK) {
+            case JS_PROP_NORMAL:
+                return js_dup(pr->u.value);
+            case JS_PROP_VARREF:
+                if (!JS_IsUninitialized(*pr->u.var_ref->pvalue))
+                    return js_dup(*pr->u.var_ref->pvalue);
+                break;
+            default:
+                break;
+            }
+            return JS_UNDEFINED;
+        }
+        p = p->shape->proto;
+    }
+    return JS_UNDEFINED;
 }
 
+static JSValue js_callsite_gettypename(JSContext *ctx, JSValueConst this_val, int argc, JSValueConst *argv)
+{
+    JSCallSiteData *csd = JS_GetOpaque2(ctx, this_val, JS_CLASS_CALL_SITE);
+    JSValue name, ctor, tag;
+    JSAtom primitive_name;
+    JSObject *p;
+    const char *name_str;
+
+    if (!csd)
+        return JS_EXCEPTION;
+
+    switch (JS_VALUE_GET_TAG(csd->this_val)) {
+    case JS_TAG_NULL:
+    case JS_TAG_UNDEFINED:
+        return JS_NULL;
+    case JS_TAG_BOOL:
+        primitive_name = JS_ATOM_Boolean;
+        break;
+    case JS_TAG_INT:
+    case JS_TAG_FLOAT64:
+        primitive_name = JS_ATOM_Number;
+        break;
+    case JS_TAG_STRING:
+    case JS_TAG_STRING_ROPE:
+        primitive_name = JS_ATOM_String;
+        break;
+    case JS_TAG_SYMBOL:
+        primitive_name = JS_ATOM_Symbol;
+        break;
+    case JS_TAG_BIG_INT:
+        primitive_name = JS_ATOM_BigInt;
+        break;
+    case JS_TAG_OBJECT:
+        primitive_name = JS_ATOM_NULL;
+        break;
+    default:
+        return JS_NULL;
+    }
+    if (primitive_name != JS_ATOM_NULL)
+        return JS_AtomToString(ctx, primitive_name);
+
+    p = JS_VALUE_GET_OBJ(csd->this_val);
+    name = JS_NULL;
+    ctor = js_callsite_get_data_property(p, JS_ATOM_constructor);
+    if (JS_IsFunction(ctx, ctor)) {
+        name_str = get_func_name(ctx, ctor);
+        if (name_str && name_str[0]) {
+            name = JS_NewString(ctx, name_str);
+            if (strcmp(name_str, "Object") != 0) {
+                JS_FreeCString(ctx, name_str);
+                JS_FreeValue(ctx, ctor);
+                return name;
+            }
+        }
+        JS_FreeCString(ctx, name_str);
+    }
+    JS_FreeValue(ctx, ctor);
+
+    tag = js_callsite_get_data_property(p, JS_ATOM_Symbol_toStringTag);
+    if (JS_IsString(tag)) {
+        JS_FreeValue(ctx, name);
+        return tag;
+    }
+    JS_FreeValue(ctx, tag);
+    if (!JS_IsNull(name))
+        return name;
+    return JS_AtomToString(ctx, ctx->rt->class_array[p->class_id].class_name);
+}
+
+static JSValue js_callsite_getmethodname(JSContext *ctx, JSValueConst this_val, int argc, JSValueConst *argv)
+{
+    JSCallSiteData *csd = JS_GetOpaque2(ctx, this_val, JS_CLASS_CALL_SITE);
+    JSObject *func, *p;
+
+    if (!csd)
+        return JS_EXCEPTION;
+    if (JS_VALUE_GET_TAG(csd->this_val) != JS_TAG_OBJECT ||
+        JS_VALUE_GET_TAG(csd->func) != JS_TAG_OBJECT)
+        return JS_NULL;
+
+    func = JS_VALUE_GET_OBJ(csd->func);
+    for (p = JS_VALUE_GET_OBJ(csd->this_val); p; p = p->shape->proto) {
+        JSShape *shape = p->shape;
+        int i;
+        for (i = 0; i < shape->prop_count; i++) {
+            JSShapeProperty *prs = &shape->prop[i];
+            JSProperty *pr = &p->prop[i];
+            bool matches = false;
+
+            if (prs->atom == JS_ATOM_NULL ||
+                JS_AtomGetKind(ctx, prs->atom) != JS_ATOM_KIND_STRING)
+                continue;
+            switch (prs->flags & JS_PROP_TMASK) {
+            case JS_PROP_NORMAL:
+                matches = JS_VALUE_GET_TAG(pr->u.value) == JS_TAG_OBJECT &&
+                          JS_VALUE_GET_OBJ(pr->u.value) == func;
+                break;
+            case JS_PROP_VARREF:
+                matches = !JS_IsUninitialized(*pr->u.var_ref->pvalue) &&
+                          JS_VALUE_GET_TAG(*pr->u.var_ref->pvalue) == JS_TAG_OBJECT &&
+                          JS_VALUE_GET_OBJ(*pr->u.var_ref->pvalue) == func;
+                break;
+            case JS_PROP_GETSET:
+                matches = pr->u.getset.getter == func ||
+                          pr->u.getset.setter == func;
+                break;
+            default:
+                break;
+            }
+            if (matches)
+                return JS_AtomToString(ctx, prs->atom);
+        }
+    }
+    return JS_NULL;
+}
+
+static JSValue js_callsite_tostring(JSContext *ctx, JSValueConst this_val, int argc, JSValueConst *argv)
+{
+    JSCallSiteData *csd = JS_GetOpaque2(ctx, this_val, JS_CLASS_CALL_SITE);
+    if (!csd)
+        return JS_EXCEPTION;
+    DynBuf dbuf;
+    const char *fn = NULL, *file = NULL;
+    js_dbuf_init(ctx, &dbuf);
+    if (JS_IsString(csd->func_name))
+        fn = JS_ToCString(ctx, csd->func_name);
+    if (fn && fn[0])
+        dbuf_printf(&dbuf, "%s (", fn);
+    if (csd->native) {
+        dbuf_printf(&dbuf, "native");
+    } else {
+        if (JS_IsString(csd->filename))
+            file = JS_ToCString(ctx, csd->filename);
+        dbuf_printf(&dbuf, "%s", file ? file : "<anonymous>");
+        if (csd->line_num != -1)
+            dbuf_printf(&dbuf, ":%d:%d", csd->line_num, csd->col_num);
+    }
+    if (fn && fn[0])
+        dbuf_putc(&dbuf, ')');
+    if (fn)
+        JS_FreeCString(ctx, fn);
+    if (file)
+        JS_FreeCString(ctx, file);
+    JSValue r;
+    if (dbuf_error(&dbuf))
+        r = JS_NULL;
+    else
+        r = JS_NewStringLen(ctx, (char *)dbuf.buf, dbuf.size);
+    dbuf_free(&dbuf);
+    return r;
+}
