diff --git a/quickjs.c b/quickjs.c
index 11caae0..a5d29c7 100644
--- a/quickjs.c
+++ b/quickjs.c
@@ -31057,6 +31197,18 @@ JSValue JS_LoadModule(JSContext *ctx, const char *basename,
     return promise;
 }
 
+/* v82jsc: embedder hook for dynamic import(). When set, js_dynamic_import calls
+   it instead of the built-in sync loader job; the hook settles resolving_funcs
+   (resolve=[0], reject=[1]) — e.g. by chaining deno's async import promise. */
+typedef void (*JSV82jscDynImportHook)(JSContext *ctx, JSValueConst basename,
+                                      JSValueConst specifier,
+                                      JSValueConst attributes,
+                                      JSValueConst *resolving_funcs);
+static JSV82jscDynImportHook v82jsc_dyn_import_hook = NULL;
+void JS_SetDynamicImportHook(JSV82jscDynImportHook fn) {
+    v82jsc_dyn_import_hook = fn;
+}
+
 static JSValue js_dynamic_import_job(JSContext *ctx,
                                      int argc, JSValueConst *argv)
 {
@@ -31177,9 +31329,18 @@ static JSValue js_dynamic_import(JSContext *ctx, JSValueConst specifier,
     args[3] = specifier_str;
     args[4] = attributes;
 
-    /* cannot run JS_LoadModuleInternal synchronously because it would
-       cause an unexpected recursion in js_evaluate_module() */
-    JS_EnqueueJob(ctx, js_dynamic_import_job, 5, vc(args));
+    /* v82jsc: when an embedder dynamic-import hook is installed (deno's async
+       HostImportModuleDynamicallyCallback bridge), route import() through it so
+       the host can fetch+compile new specifiers asynchronously and settle the
+       resolving_funcs. Falls back to QuickJS's built-in sync loader job. */
+    if (v82jsc_dyn_import_hook) {
+        v82jsc_dyn_import_hook(ctx, basename_val, specifier_str, attributes,
+                               resolving_funcs);
+    } else {
+        /* cannot run JS_LoadModuleInternal synchronously because it would
+           cause an unexpected recursion in js_evaluate_module() */
+        JS_EnqueueJob(ctx, js_dynamic_import_job, 5, vc(args));
+    }
 done:
     JS_FreeValue(ctx, basename_val);
     JS_FreeValue(ctx, resolving_funcs[0]);
