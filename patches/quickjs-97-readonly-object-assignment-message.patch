+static int JS_ThrowTypeErrorReadOnlyProperty(JSContext *ctx, int flags,
+                                             JSAtom atom,
+                                             JSValueConst receiver)
+{
+    if (JS_VALUE_GET_TAG(receiver) == JS_TAG_OBJECT &&
+        JS_VALUE_GET_OBJ(receiver)->class_id == JS_CLASS_OBJECT &&
+        ((flags & JS_PROP_THROW) ||
+         ((flags & JS_PROP_THROW_STRICT) && is_strict_mode(ctx)))) {
+        JS_ThrowTypeErrorAtom(ctx,
+                              "Cannot assign to read only property '%s' of object '#<Object>'",
+                              atom);
+        return -1;
+    }
+    return JS_ThrowTypeErrorReadOnly(ctx, flags, atom);
+}
