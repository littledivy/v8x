diff --git a/quickjs.c b/quickjs.c
index d52fd4e..10f4eca 100644
--- a/quickjs.c
+++ b/quickjs.c
@@ -377,6 +377,7 @@ struct JSRuntime {
     // for smuggling the parent promise from js_promise_then
     // to js_promise_constructor
     JSValueLink *parent_promise;
+    JSValueLink *kept_objects;
 
     JSJobContextCapture *job_context_capture;
     JSJobContextSet *job_context_set;
@@ -2791,6 +2792,7 @@ void JS_FreeRuntime(JSRuntime *rt)
 
     rt->in_free = true;
     JS_FreeValueRT(rt, rt->current_exception);
+    JS_ClearKeptObjects(rt);
 
     list_for_each_safe(el, el1, &rt->job_list) {
         JSJobEntry *e = list_entry(el, JSJobEntry, link);
@@ -65525,6 +65527,29 @@ static void js_weakref_finalizer(JSRuntime *rt, JSValueConst val)
     js_free_rt(rt, wr);
 }
 
+static int js_keep_object(JSContext *ctx, JSValueConst value)
+{
+    JSValueLink *link = js_malloc(ctx, sizeof(*link));
+    if (!link)
+        return -1;
+    link->value = js_dup(value);
+    link->next = ctx->rt->kept_objects;
+    ctx->rt->kept_objects = link;
+    return 0;
+}
+
+void JS_ClearKeptObjects(JSRuntime *rt)
+{
+    JSValueLink *link = rt->kept_objects;
+    rt->kept_objects = NULL;
+    while (link) {
+        JSValueLink *next = link->next;
+        JS_FreeValueRT(rt, link->value);
+        js_free_rt(rt, link);
+        link = next;
+    }
+}
+
 static JSValue js_weakref_constructor(JSContext *ctx, JSValueConst new_target,
                                       int argc, JSValueConst *argv)
 {
@@ -65555,6 +65580,10 @@ static JSValue js_weakref_constructor(JSContext *ctx, JSValueConst new_target,
     insert_weakref_record(arg, wr);
 
     JS_SetOpaqueInternal(obj, wrd);
+    if (js_keep_object(ctx, arg)) {
+        JS_FreeValue(ctx, obj);
+        return JS_EXCEPTION;
+    }
     return obj;
 }
 
@@ -65565,6 +65594,8 @@ static JSValue js_weakref_deref(JSContext *ctx, JSValueConst this_val, int argc,
         return JS_EXCEPTION;
     if (wrd == &js_weakref_sentinel)
         return JS_UNDEFINED;
+    if (js_keep_object(ctx, wrd->target))
+        return JS_EXCEPTION;
     return js_dup(wrd->target);
 }
 
